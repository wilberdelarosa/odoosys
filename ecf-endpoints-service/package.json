{
  "name": "ecf-endpoints-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": "dist/server.js",
  "scripts": {
    "dev": "tsx src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start:prod": "node dist/server.js",
    "check": "tsc --noEmit",
    "test:system": "tsx src/system-test.ts",
    "verify:local-node": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-local-node.ps1",
    "test:system:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-system-test-local.ps1",
    "bundle:exe": "esbuild src/server.ts --bundle --platform=node --target=node22 --format=cjs --outfile=build/server.cjs",
    "build:exe": "npm run build && npm run bundle:exe && pkg build/server.cjs --config package.json --target node22-win-x64 --compress Zstd --fallback-to-source --output build/ecf-service.exe"
  },
  "pkg": {
    "assets": [
      "public/**/*"
    ]
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.11",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "node-forge": "^1.3.1",
    "xml-crypto": "^6.1.2",
    "xml-js": "^1.6.11",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "@yao-pkg/pkg": "^6.21.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.0",
    "typescript": "^5.8.2"
  }
}
