{
  "name": "ecf-endpoints-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start:prod": "node dist/server.js",
    "check": "tsc --noEmit",
    "test:system": "tsx src/system-test.ts",
    "verify:local-node": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-local-node.ps1",
    "test:system:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-system-test-local.ps1"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.11",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "node-forge": "^1.3.1",
    "xml-crypto": "^6.1.2",
    "xml-js": "^1.6.11",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
