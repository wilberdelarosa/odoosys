<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_stock_scan_do" model="ir.ui.view">
        <field name="name">stock.picking.form.stock.scan.do</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_stock_scan_wizard"
                        type="object"
                        string="Escanear"
                        class="oe_highlight"
                        invisible="state in ('done', 'cancel')"/>
            </xpath>
            <xpath expr="//sheet/group" position="inside">
                <group string="Escaneo Community" invisible="state in ('done', 'cancel')">
                    <field name="stock_scan_last_code" readonly="1"/>
                    <field name="stock_scan_last_message" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>