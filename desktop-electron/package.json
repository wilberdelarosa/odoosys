{
  "name": "dgii-ecf-desktop",
  "version": "1.1.0",
  "private": true,
  "description": "Aplicacion desktop local DGII e-CF sobre backend Node sin Docker ni Odoo.",
  "author": "wilberdelarosa",
  "type": "module",
  "main": "main.mjs",
  "scripts": {
    "prepare:service": "npm --prefix ../ecf-endpoints-service run build && node scripts/prepare-service.mjs",
    "dev": "npm run prepare:service && electron .",
    "test:desktop": "npm run prepare:service && electron . --test-mode",
    "dist:dir": "npm run prepare:service && electron-builder --dir",
    "dist:win": "npm run prepare:service && electron-builder --win nsis portable"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.11",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "node-forge": "^1.3.1",
    "xml-crypto": "^6.1.2",
    "xml-js": "^1.6.11",
    "xpath": "^0.0.34"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.dgii.ecf.desktop",
    "productName": "DGII e-CF Desktop",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "main.mjs",
      "preload.mjs",
      "service/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "DGII-eCF-Desktop-Setup-${version}-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "DGII-eCF-Desktop-Portable-${version}-${arch}.${ext}"
    }
  }
}
